(set-logic QF_BV)
(declare-const k (_ BitVec 32))
(define-const velocity (_ BitVec 32) k)
(define-const position (_ BitVec 32)
  (bvudiv (bvmul k (bvsub k #x00000001)) #x00000002))
(assert (bvule k #x000000c9))
(assert (and (bvuge velocity #x000000c9)
             (bvuge position #x00004e84)))
(check-sat)
